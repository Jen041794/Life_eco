# === 環境變數範本 ===
# 複製這個檔成 .env，再把值換成你自己的。.env 不會進 git。
#   PowerShell:  Copy-Item .env.example .env

# Django
DJANGO_SECRET_KEY=請用 python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())" 產生一把
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# 資料庫（本機開發用 MySQL）
DB_NAME=ecommerce_db
DB_USER=root
DB_PASSWORD=你的資料庫密碼
DB_HOST=localhost
DB_PORT=3306

# === 正式部署才需要的環境變數（本機留空即可，會自動沿用上面的 MySQL）===
# 正式環境設 Supabase PostgreSQL 連線字串，設了就優先用它（蓋過上面的 MySQL）
# 範例：postgresql://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=
# 前端正式網址（逗號分隔），讓 API 接受跨網域請求；例：https://life-eco.vercel.app
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=
